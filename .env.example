# ============================================================
#  Artvelle — environment variables
#  Copy this file to .env and fill in your own values.
# ============================================================

# --- Database (required) ---------------------------------------------------
# From Vercel Postgres / Neon. Use the POOLED url for DATABASE_URL and the
# DIRECT (non-pooled) url for DIRECT_URL (used by Prisma migrations).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Admin login (required) ------------------------------------------------
# A long random string that signs the admin session cookie.
AUTH_SECRET="change-me-to-a-long-random-string"
# The first admin account (created by the seed script; also a login fallback).
ADMIN_EMAIL="admin@artvelle.com"
ADMIN_PASSWORD="a-strong-password"

# --- Email notifications (optional but recommended) ------------------------
# Get a free key at https://resend.com. Without it, emails are skipped.
RESEND_API_KEY=""
# The "from" address. Use onboarding@resend.dev to start, or your own verified domain.
EMAIL_FROM="Artvelle <onboarding@resend.dev>"

# --- Image uploads (optional) ----------------------------------------------
# Create a Vercel Blob store; Vercel injects this automatically on deploy.
# Locally, copy it from the Vercel dashboard. Without it, paste image URLs.
BLOB_READ_WRITE_TOKEN=""
